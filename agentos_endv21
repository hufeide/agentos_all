class ToolRegistry:
    """工具注册中心 - 管理所有可用工具"""

    def __init__(self):
        self.tools: Dict[str, Callable[..., Any]] = {}
        self.tool_schemas: Dict[str, Dict[str, Any]] = {}
        self.tool_descriptions: Dict[str, str] = {}

    def register(
        self,
        name: str,
        func: Callable[..., Any],
        description: str,
        params_schema: Optional[Dict[str, Any]] = None
    ):
        """注册工具"""
        self.tools[name] = func
        self.tool_schemas[name] = {
            "type": "function",
            "function": {
                "name": name,
                "description": description,
                "parameters": params_schema or {"type": "object", "properties": {}}
            }
        }
        self.tool_descriptions[name] = description
        logger.debug(f"[ToolRegistry] Registered tool: {name}")

    def get_available_tools(self) -> List[Dict[str, Any]]:
        """获取可用工具列表（用于 LLM Prompt）"""
        return list(self.tool_schemas.values())

    def get_available_tool_names(self) -> List[str]:
        """获取可用工具名称列表"""
        return list(self.tools.keys())

    def has_available_tools(self) -> bool:
        """是否有可用工具"""
        return len(self.tools) > 0

    async def execute(self, tool_name: str, args: Dict[str, Any]) -> Any:
        """执行工具"""
        if tool_name not in self.tools:
            return f"错误：工具 '{tool_name}' 不存在"
        try:
            result = await self.tools[tool_name](**args)
            return result
        except Exception as e:
            return f"错误：工具 '{tool_name}' 执行失败: {str(e)}"


class SkillRegistry:
    """Skill 注册中心 - 管理所有 Skills"""

    def __init__(self):
        self.skills: Dict[str, Any] = {}
        self.skill_schemas: Dict[str, Dict[str, Any]] = {}

    def register(self, name: str, skill: Any, description: str = "", params_schema: Optional[Dict[str, Any]] = None):
        """注册 Skill"""
        self.skills[name] = skill
        self.skill_schemas[name] = {
            "type": "skill",
            "name": name,
            "description": description,
            "parameters": params_schema or {"type": "object", "properties": {}}
        }
        logger.debug(f"[SkillRegistry] Registered skill: {name}")

    def get_available_skills(self) -> List[Dict[str, Any]]:
        """获取可用 Skills 列表"""
        return list(self.skill_schemas.values())

    def get_available_skill_names(self) -> List[str]:
        """获取可用 Skill 名称列表"""
        return list(self.skills.keys())

    async def execute(self, skill_name: str, args: Dict[str, Any]) -> Any:
        """执行 Skill"""
        if skill_name not in self.skills:
            return f"错误：Skill '{skill_name}' 不存在"
        try:
            result = await self.skills[skill_name].run(**args)
            return result
        except Exception as e:
            return f"错误：Skill '{skill_name}' 执行失败: {str(e)}"


