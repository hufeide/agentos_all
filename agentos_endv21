class StepType(str, Enum):
    """步骤类型常量 - 避免魔法字符串"""
    THINK = "think"
    SEARCH = "search"
    RESEARCH = "research"
    ANALYZE = "analyze"
    ANSWER = "answer"
    SUMMARIZE = "summarize"
    TOOL = "tool"

    @classmethod
    def all_types(cls) -> List[str]:
        return [cls.THINK, cls.SEARCH, cls.RESEARCH, cls.ANALYZE, cls.ANSWER, cls.SUMMARIZE, cls.TOOL]

    @classmethod
    def is_generic(cls, step_type: str) -> bool:
        """判断是否为可能导致无限循环的通用类型"""
        return step_type in [cls.THINK, cls.ANALYZE, cls.SUMMARIZE]


