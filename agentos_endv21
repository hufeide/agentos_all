async def main():
    # 创建 agent 并加载 skills
    agent = ProductionAgentOS(worker_count=2, skills_dir="skills")

    # 示例 1：用户指定工作流
    # task = "只搜索 AH 股溢价相关信息"

    # 示例 2：用户要求只搜索
    # task = "只搜索 AH 股溢价相关信息"

    # 示例 3：默认模式（让系统自动决定）
    task = "搜索 AH 股溢价，分析 AH 股溢价对当前市场情绪的影响"

    # 打印可用的 skills
    logger.info(f"可用 Skills: {agent.skill_registry.get_available_skill_names()}")

    try:
        result = await agent.run(task, timeout=300)
        logger.info("=" * 70)
        logger.info("最终结果")
        logger.info("=" * 70)
        logger.info(f"Status: {result['status']}")
        logger.info(f"Completed: {result['completed_steps']}/{result['total_steps']} steps")
        logger.info(f"Duration: {result['duration']:.1f}s")

        # 显示步骤详细输出
        proj = agent.store.get_projection(result["task_id"])
        if proj:
            completed_records = [r for r in proj.step_records if r.get("status") == "completed"]
            for record in completed_records:
                logger.info("-" * 50)
                logger.info(f"步骤 {record['phase']}: {record['step_type'].upper()}")
                output = record.get("output_full") or record.get("output", "")
                if output:
                    # 显示前1000字符
                    logger.info(f"输出内容:\n{output[:1000]}")

        logger.info("=" * 70)
    except Exception as e:
        logger.error(f"错误：{e}")
        import traceback
        traceback.print_exc()

if __name__ == "__main__":
    asyncio.run(main())

