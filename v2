# 事务性事件存储 (🔧 修复退出慢)
# =========================
class EventStore:
    def __init__(self, bus: 'EventBus'):
        self._logs = defaultdict(list)
        self._projections: Dict[str, TaskProjection] = {}
        self._bus = bus
        self._task_locks: Dict[str, asyncio.Lock] = {}
        self._global_lock = asyncio.Lock()
        self._cleanup_task: Optional[asyncio.Task] = None
        self._cleanup_interval = 60
        self._stop_event = asyncio.Event()  # 🔧 新增：停止信号

    async def start_cleanup(self):
        self._cleanup_task = asyncio.create_task(self._cleanup_loop())

    async def _cleanup_loop(self):
        # 🔧 修复：可立即响应取消的清理循环
        while not self._stop_event.is_set():
            try:
                await asyncio.wait_for(self._stop_event.wait(), timeout=self._cleanup_interval)
                break
            except asyncio.TimeoutError:
                pass
            now = time.time()
            to_delete = []
            async with self._global_lock:
                for tid, proj in list(self._projections.items()):
                    if proj.is_terminal and proj.end_time and now - proj.end_time > AgentOSDefaults.PROJECTION_CLEANUP_DELAY:
                        to_delete.append(tid)
                for tid in to_delete:
                    del self._projections[tid]
                    self._logs.pop(tid, None)
                    self._task_locks.pop(tid, None)
                if to_delete:
                    logger.info(f"[EventStore] Cleaned up {len(to_delete)} tasks")

    def _get_task_lock(self, task_id: str) -> asyncio.Lock:
        if task_id not in self._task_locks:
            self._task_locks[task_id] = asyncio.Lock()
        return self._task_locks[task_id]

    async def append_and_publish(self, event: Event, max_retries: int = 3):
        tid = event.task_id
        lock = self._get_task_lock(tid)

        async with lock:
            self._logs[tid].append(event)
            async with self._global_lock:
                if event.event_type == EventType.TASK_SUBMITTED and tid not in self._projections:
                    task_text = event.payload.get("task", "")
                    self._projections[tid] = TaskProjection(tid, task_text)
            if tid in self._projections:
                self._projections[tid].apply(event)
            if event.event_type == EventType.STEP_COMPLETED and event.step_id:
                proj = self._projections[tid]
                asyncio.create_task(self._async_print_report(proj, event.step_id))

        last_error = None
        for attempt in range(max_retries + 1):
            try:
                await self._bus.publish(event)
                return
            except Exception as e:
                last_error = e
                if attempt < max_retries:
                    logger.warning(f"[EventStore] Publish failed (attempt {attempt + 1}), retrying: {e}")
                    await asyncio.sleep(0.05 * (attempt + 1))  # 🔧 优化：减少重试间隔
                else:
                    logger.error(f"[EventStore] Publish failed after {max_retries + 1} attempts: {e}")
        if last_error:
            raise last_error

    async def _async_print_report(self, proj: TaskProjection, step_id: str):
        proj.print_phase_report(step_id)

    async def try_claim_step(self, task_id: str, step_id: str, worker_id: str, max_retries: int = 2) -> bool:
        lock = self._get_task_lock(task_id)
        async with lock:
            proj = self._projections.get(task_id)
            if not proj:
                logger.warning(f"[EventStore] Claim failed: projection missing for {task_id[:8]}")
                return False
            if proj.is_terminal:
                logger.debug(f"[EventStore] Claim failed: task {task_id[:8]} is terminal")
                return False
            if step_id not in proj.ready_pool:
                logger.warning(f"[EventStore] Claim failed: step {step_id[:8]} not in ready_pool (current ready: {proj.get_ready_pool_steps()[:5]})")
                return False

            event = Event(
                task_id=task_id,
                step_id=step_id,
                event_type=EventType.STEP_CLAIMED,
                payload={"worker": worker_id}
            )
            self._logs[task_id].append(event)
            proj.apply(event)

        # 锁外执行发布操作（避免持有任务锁）
        publish_success = False
        for attempt in range(max_retries + 1):
            try:
                await self._bus.publish(event)
                logger.info(f"[EventStore] Step {step_id[:8]} claimed by {worker_id}")
                publish_success = True
                break
            except asyncio.CancelledError:
                # 可重试：任务被取消，可能是网络问题
                if attempt < max_retries:
                    logger.warning(f"[EventStore] Publish cancelled, retry {attempt + 1}/{max_retries}")
                    await asyncio.sleep(0.1 * (attempt + 1))
                    continue
                logger.error(f"[EventStore] Publish cancelled after {max_retries + 1} attempts")
                break
            except TimeoutError:
                # 可重试：超时错误
                if attempt < max_retries:
                    logger.warning(f"[EventStore] Publish timeout, retry {attempt + 1}/{max_retries}")
                    await asyncio.sleep(0.1 * (attempt + 1))
                    continue
                logger.error(f"[EventStore] Publish timeout after {max_retries + 1} attempts")
                break
            except Exception as e:
                # 不可重试：其他异常（如序列化错误、事件总线关闭等）
                logger.error(f"[EventStore] Failed to publish STEP_CLAIMED: {e}")
                break

        # 锁内恢复步骤状态（无论成功或失败都需要清理）
        async with lock:
            if not publish_success:
                proj.ready_pool.add(step_id)
                proj.running.pop(step_id, None)
        return publish_success

    def get_projection(self, task_id: str) -> Optional[TaskProjection]:
        return self._projections.get(task_id)

    def get_all_projections(self) -> Dict[str, TaskProjection]:
        """获取所有任务投影（用于调度器遍历）"""
        return self._projections

    def get_logs(self, task_id: str) -> List[Event]:
        return self._logs.get(task_id, [])

    def get_task_lock(self, task_id: str) -> asyncio.Lock:
        """公开方法：获取任务级锁（供 Scheduler 使用）"""
        return self._get_task_lock(task_id)

    async def shutdown(self):
        # 🔧 修复：通知 cleanup 循环立即退出
        self._stop_event.set()
        if self._cleanup_task:
            self._cleanup_task.cancel()
            try:
                await self._cleanup_task
            except asyncio.CancelledError:
                pass
        await asyncio.sleep(0)

# =========================
# 事件总线 (🔧 修复退出慢)
# =========================
class EventBus:
    def __init__(self):
        self._subscribers: List[Callable] = []
        self._queue: asyncio.Queue = asyncio.Queue()
        self._worker_task = asyncio.create_task(self._process_queue())
        self._stop_event = asyncio.Event()

    def subscribe(self, handler: Callable):
        self._subscribers.append(handler)
        handler_name = getattr(handler, '__name__', repr(handler))
        logger.debug(f"[EventBus] Subscribed {handler_name}, total handlers: {len(self._subscribers)}")
        return len(self._subscribers) - 1  # 返回订阅ID

    async def publish(self, event: Event):
        logger.debug(f"[EventBus] Publishing event {event.event_type.value} for task {event.task_id[:8]}")
        await self._queue.put(event)

    async def _process_queue(self):
        while not self._stop_event.is_set():
            try:
                event = await asyncio.wait_for(self._queue.get(), timeout=AgentOSDefaults.QUEUE_TIMEOUT)
                if event is None:  # 🔧 毒丸事件，退出循环
                    break
                logger.debug(f"[EventBus] Processing event {event.event_type.value} for task {event.task_id[:8]}, handlers: {len(self._subscribers)}")
            except asyncio.TimeoutError:
                # 🔧 修复：检查停止信号，允许毒丸事件被及时处理
                if self._stop_event.is_set():
                    break
                continue
            coros = [self._safe_run(handler, event) for handler in self._subscribers]
            logger.debug(f"[EventBus] Calling {len(coros)} handlers for event {event.event_type.value}")
            results = await asyncio.gather(*coros, return_exceptions=True)
            for handler, result in zip(self._subscribers, results):
                if isinstance(result, Exception):
                    handler_name = getattr(handler, '__name__', repr(handler))
                    logger.error(f"[EventBus] Handler {handler_name} failed: {result}")
                else:
                    logger.debug(f"[EventBus] Handler completed successfully")
            self._queue.task_done()

    async def _safe_run(self, handler: Callable, event: Event) -> Optional[Exception]:
        handler_name = getattr(handler, '__name__', repr(handler))
        logger.debug(f"[EventBus] Calling handler {handler_name} for event {event.event_type.value}")
        try:
            await handler(event)
            return None
        except Exception as e:
            logger.error(f"[EventBus] Handler {handler_name} failed: {e}", exc_info=True)
            return e

    async def shutdown(self):
        # 🔧 修复：通知处理循环退出，然后放入毒丸唤醒阻塞的队列
        self._stop_event.set()
        # 放入毒丸事件唤醒可能阻塞在 queue.get() 的协程
        try:
            await asyncio.wait_for(self._queue.put(None), timeout=0.5)
        except asyncio.QueueFull:
            pass  # 队列已满，处理循环迟早会处理到毒丸
        except asyncio.TimeoutError:
            pass
        try:
            await asyncio.wait_for(self._worker_task, timeout=2.0)
        except asyncio.TimeoutError:
            logger.warning("[EventBus] Shutdown timeout, forcing exit")
            self._worker_task.cancel()
            try:
                await self._worker_task
            except asyncio.CancelledError:
                pass
        except asyncio.CancelledError:
            pass

