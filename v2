class ProductionAgentOS:
    def __init__(self, worker_count: int = 2, skills_dir: str = "skills"):
        self.bus = EventBus()
        self.store = EventStore(self.bus)
        self.queue = asyncio.Queue()
        self.scheduler = Scheduler(self.store, self.queue)
        self.worker_count = worker_count
        self.workers: List[Worker] = []
        self.tool_registry = ToolRegistry()  # 🔧 新增：工具注册中心
        self.skill_registry = SkillRegistry()  # 🔧 新增：Skill 注册中心
        self.skills_dir = skills_dir
        self._global_timeout_task: Optional[asyncio.Task] = None
        self.bus.subscribe(self.scheduler.on_event)

        # 🔧 加载并注册 skills
        self._register_skills()

        logger.info(f"🚀 ProductionAgentOS initialized with {worker_count} workers")

    def _register_skills(self):
        """从目录加载并注册 skills"""
        try:
            skills = load_skills_from_directory(self.skills_dir)
            for skill_name, skill_obj in skills.items():
                self.skill_registry.register(
                    name=skill_name,
                    skill=skill_obj,
                    description=skill_obj.description
                )
            logger.info(f"[ProductionAgentOS] Registered {len(skills)} skills")
        except Exception as e:
            logger.error(f"[ProductionAgentOS] Failed to load skills: {e}")

    def register_tool(self, name: str, func: Callable, description: str, params_schema: Optional[Dict] = None):
        """注册工具到全局注册中心"""
        self.tool_registry.register(name, func, description, params_schema)
        logger.info(f"[ProductionAgentOS] Registered global tool: {name}")

    def register_skill(self, name: str, skill: Any, description: str = "", params_schema: Optional[Dict] = None):
        """注册 Skill 到全局注册中心"""
        self.skill_registry.register(name, skill, description, params_schema)
        logger.info(f"[ProductionAgentOS] Registered global skill: {name}")

    def _create_initial_step(self, task: str, task_id: str) -> List[Dict]:
        """创建初始 think 步骤"""
        # task_id 保留供未来使用
        _ = task_id
        initial_step = StepDefine(
            step_id=f"step-{uuid.uuid4().hex[:8]}",
            step_type="think",
            input_data={"task": task, "phase": "initial_analysis"},
            dependencies=[]
        )
        return [initial_step.__dict__]

    async def run(self, task: str, timeout: float = 300.0) -> Dict:
        """Modern Agent 模式：单次 LLM 调用 + 工具调用"""
        task_id = str(uuid.uuid4())

        print(f"\n{'='*70}")
        print(f"🚀 任务启动 (Modern Agent 模式)")
        print(f"{'='*70}")
        print(f"任务 ID: {task_id[:8]}")
        print(f"任务描述：{task[:60]}...")
        print(f"可用工具: {len(self.tool_registry.get_available_tools())} 个")
        print(f"可用 Skills: {len(self.skill_registry.get_available_skills())} 个")
        print(f"开始时间：{time.strftime('%H:%M:%S')}")
        print(f"Workers: {self.worker_count}")
        print(f"{'='*70}\n")

        # 🔧 创建 Worker 时传入全局工具注册中心
        self.workers = [
            Worker(f"W-{i}", self.queue, self.store, self.scheduler, self.tool_registry, self.skill_registry)
            for i in range(self.worker_count)
        ]
        worker_tasks = [asyncio.create_task(w.run()) for w in self.workers]

        self.scheduler._scan_task = asyncio.create_task(self.scheduler.start_periodic_scan(interval=5.0))
        await self.store.start_cleanup()

        await asyncio.sleep(0.3)

        completion_future = asyncio.get_running_loop().create_future()
        self.scheduler.register_completion(task_id, completion_future)

        async def global_timeout():
            try:
                await asyncio.sleep(timeout)
                if not completion_future.done():
                    logger.error(f"⏱️ 全局超时 {timeout}s，强制结束任务")
                    await self.store.append_and_publish(Event(
                        task_id=task_id,
                        event_type=EventType.TASK_FAILED,
                        payload={"reason": "global_timeout"}
                    ))
                    for w in self.workers:
                        w.stop()
                    for t in worker_tasks:
                        t.cancel()
            except asyncio.CancelledError:
                pass

        self._global_timeout_task = asyncio.create_task(global_timeout())

        # 🔧 Modern Agent 模式：不预创建步骤，让 LLM 在执行过程中动态决定
        # 创建一个初始的 think 步骤作为入口
        # initial_step 保留供未来使用
        initial_step = StepDefine(
            step_id=f"step-{uuid.uuid4().hex[:8]}",
            step_type="think",  # 初始步骤类型
            input_data={"task": task, "phase": "initial_analysis"},
            dependencies=[]
        )
        # initial_step 未使用，保留供未来使用
        _ = initial_step

        # 创建初始步骤
        steps_data = self._create_initial_step(task, task_id)
        logger.info(f"[Workflow] Created initial step: {[s['step_type'] for s in steps_data]}")

        try:
            await self.store.append_and_publish(Event(
                task_id=task_id,
                event_type=EventType.TASK_SUBMITTED,
                payload={
                    "task": task,
                    "dag": steps_data
                }
            ))
        except Exception as e:
            logger.error(f"Failed to submit task: {e}")
            # 发布 TASK_FAILED 事件通知任务失败
            try:
                await self.store.append_and_publish(Event(
                    task_id=task_id,
                    event_type=EventType.TASK_FAILED,
                    payload={"reason": "submit_failed", "error": str(e)}
                ))
            except Exception:
                pass  # 如果发布失败，忽略（可能是事件总线已关闭）
            # 停止所有 worker
            for w in self.workers:
                w.stop()
            for t in worker_tasks:
                t.cancel()
            if self._global_timeout_task:
                self._global_timeout_task.cancel()
            if self.scheduler._scan_task:
                self.scheduler._scan_task.cancel()
            return {"task_id": task_id, "status": "submit_failed", "error": str(e), "completed_steps": 0, "total_steps": 0, "duration": 0}

        try:
            result_status = await asyncio.wait_for(completion_future, timeout=timeout + 5)
            proj = self.store.get_projection(task_id)
            result = {
                "task_id": task_id,
                "status": result_status.value if hasattr(result_status, 'value') else result_status,
                "completed_steps": len(proj.completed) if proj else 0,
                "total_steps": len(proj.steps) if proj else 0,
                "duration": (proj.end_time - proj.start_time) if proj and proj.end_time else 0
            }
            return result
        except asyncio.TimeoutError:
            logger.error("⏱️ 任务超时")
            proj = self.store.get_projection(task_id)
            if proj:
                logger.error(f"Final status: {proj.get_status()}")
            # 🔧 修复：超时返回也包含 completed_steps 和 total_steps
            return {
                "task_id": task_id,
                "status": "timeout",
                "completed_steps": len(proj.completed) if proj else 0,
                "total_steps": len(proj.steps) if proj else 0,
                "duration": timeout
            }
        finally:
            if self._global_timeout_task:
                self._global_timeout_task.cancel()
            await self.scheduler.shutdown()
            logger.info("Shutting down workers...")
            for w in self.workers:
                w.stop()
            try:
                await asyncio.wait_for(asyncio.gather(*worker_tasks, return_exceptions=True), timeout=5.0)
            except asyncio.TimeoutError:
                logger.warning("Worker shutdown timeout")
            # 🔧 关闭共享资源
            await Worker.shutdown_shared_resources()
            await self.bus.shutdown()
            await self.store.shutdown()

    async def shutdown(self):
        """Shutdown agent gracefully"""
        await self.scheduler.shutdown()
        logger.info("Shutting down workers...")
        for w in self.workers:
            w.stop()
        try:
            await asyncio.wait_for(asyncio.gather(*[asyncio.create_task(w.run()) for w in self.workers], return_exceptions=True), timeout=5.0)
        except asyncio.TimeoutError:
            logger.warning("Worker shutdown timeout")
        await Worker.shutdown_shared_resources()
        await self.bus.shutdown()
        await self.store.shutdown()

