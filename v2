# 智能调度器
# =========================
class Scheduler:
    def __init__(self, store: EventStore, queue: asyncio.Queue):
        self.store = store
        self.queue = queue
        self._completion_futures: Dict[str, asyncio.Future] = {}
        self._last_dispatch: Dict[str, Dict[str, float]] = defaultdict(dict)
        self._stop_event = asyncio.Event()
        self._scan_task: Optional[asyncio.Task] = None
        self._pending_steps: Set[str] = set()
        self._state_lock = asyncio.Lock()

    async def start_periodic_scan(self, interval: float = 5.0):
        while not self._stop_event.is_set():
            await asyncio.sleep(interval)
            if self._stop_event.is_set():
                break
            await self._scan_and_retry_ready_steps()

    async def _scan_and_retry_ready_steps(self):
        now = time.time()
        for task_id, proj in self.store.get_all_projections().items():
            if proj.is_terminal:
                continue
            for step_id in list(proj.ready_pool):
                step = proj.steps.get(step_id)
                if step is None:
                    logger.warning(f"[Scheduler] Step {step_id[:8]} not found in steps")
                    proj.ready_pool.discard(step_id)
                    continue
                last_ready = proj.step_last_ready_time.get(step_id, 0)
                if now - last_ready > AgentOSDefaults.REDISPATCH_THRESHOLD:
                    logger.info(f"[Scheduler] Re-dispatching step {step_id[:8]} (idle >10s)")
                    # 发布重调度事件
                    event = Event(
                        task_id=task_id,
                        step_id=step_id,
                        event_type=EventType.STEP_READY,
                        payload={"step_type": step.step_type}
                    )
                    try:
                        await self.store.append_and_publish(event)
                    except Exception as e:
                        logger.error(f"[Scheduler] Failed to re-dispatch step {step_id[:8]}: {e}")

    async def on_event(self, event: Event):
        # 🔧 优化：减少日志输出
        if logger.isEnabledFor(logging.DEBUG):
            logger.debug(f"[Scheduler] Received {event.event_type.value} for {event.task_id[:8]}")

        # === 终端事件处理（保持不变）===
        if event.event_type in (EventType.TASK_COMPLETED, EventType.TASK_FAILED):
            fut = self._completion_futures.get(event.task_id)
            if fut and not fut.done():
                fut.set_result(event.event_type)
                logger.info(f"[Scheduler] ✅ Completion future set: {event.event_type.value}")
            proj = self.store.get_projection(event.task_id)
            if proj:
                proj.print_final_summary()
            async with self._state_lock:
                self._last_dispatch.pop(event.task_id, None)
            return

        if event.event_type == EventType.STEP_CLAIMED:
            async with self._state_lock:
                self._pending_steps.discard(event.step_id)
            return

        # === STEP_COMPLETED 事件处理：检查是否是终端步骤 ===
        if event.event_type == EventType.STEP_COMPLETED:
            proj = self.store.get_projection(event.task_id)
            if proj and not proj.is_terminal:
                is_terminal_step = event.payload.get("is_terminal", False)
                # 🔧 使用 has_uncompleted_steps 方法检查是否还有未完成的步骤
                if is_terminal_step and not proj.has_uncompleted_steps():
                    logger.info(f"[Scheduler] ✅ All steps completed, publishing TASK_COMPLETED")
                    # 发布 TASK_COMPLETED 事件
                    await self.store.append_and_publish(Event(
                        task_id=event.task_id,
                        event_type=EventType.TASK_COMPLETED,
                        payload={"reason": "all_steps_completed"}
                    ))
                    # 🔧 修复：不再直接设置状态，等待 TASK_COMPLETED 事件处理
                    async with self._state_lock:
                        self._last_dispatch.pop(event.task_id, None)
                    return

        if event.event_type not in (
            EventType.TASK_SUBMITTED, EventType.STEP_FAILED,
            EventType.STEP_RETRY, EventType.STEP_DEAD, EventType.STEP_READY, EventType.DAG_UPDATED
        ):
            return

        # === 收集需要执行的操作（锁内只读）===
        task_lock = self.store.get_task_lock(event.task_id)
        events_to_publish = []
        steps_to_queue = []
        deadlock_event = None  # 🔧 新增标记

        async with task_lock:
            proj = self.store.get_projection(event.task_id)
            if not proj or proj.is_terminal:
                return

            # === DAG_UPDATED 事件处理 ===
            if event.event_type == EventType.DAG_UPDATED:
                # 检查是否有新的就绪步骤
                proj.check_ready_steps()
                # 收集需要入队的步骤（锁内只读，记录操作）
                newly_queued = []
                for step_id in list(proj.ready_pool):
                    step = proj.steps.get(step_id)
                    if step and step_id not in proj.completed and step_id not in proj.running:
                        deps = set(step.dependencies)
                        if deps.issubset(proj.completed):
                            newly_queued.append((event.task_id, step_id))
                            logger.debug(f"[Scheduler] New step {step_id[:8]} queued after DAG update")
                # 清空新加入的步骤
                for sid in newly_queued:
                    proj.ready_pool.discard(sid[1])
                # 锁外执行入队操作
                for item in newly_queued:
                    steps_to_queue.append(item)
                return

            if event.event_type == EventType.STEP_READY:
                step_id = event.step_id
                # 锁内检查状态
                async with self._state_lock:
                    if step_id in self._pending_steps:
                        logger.debug(f"[Scheduler] Step {step_id[:8]} already pending, skipping")
                        return
                    self._pending_steps.add(step_id)
                # 锁外执行入队操作
                steps_to_queue.append((event.task_id, step_id))
                logger.debug(f"[Scheduler] Re-dispatched step {step_id[:8]} from ready event")
                return

            runnable = proj.get_runnable_steps()
            if runnable:
                logger.debug(f"[Scheduler] Found {len(runnable)} runnable steps for task {event.task_id[:8]}")
                for step in runnable:
                    async with self._state_lock:
                        if step.step_id in self._pending_steps:
                            continue
                        now = time.time()
                        last = self._last_dispatch[event.task_id].get(step.step_id, 0)
                        if now - last < 1.0:
                            continue
                        self._last_dispatch[event.task_id][step.step_id] = now
                        self._pending_steps.add(step.step_id)

                    ready_event = Event(
                        task_id=event.task_id,
                        step_id=step.step_id,
                        event_type=EventType.STEP_READY,
                        payload={"step_type": step.step_type}
                    )
                    events_to_publish.append(ready_event)
                    steps_to_queue.append((event.task_id, step.step_id))
                    logger.debug(f"[Scheduler] Prepared dispatch step {step.step_id[:8]} ({step.step_type})")
            # 🔧 修复：移除过于激进的完成检查，改为合理的死锁检测
            else:
                # proj 已在锁内获取，直接使用
                if proj and not proj.is_terminal:
                    # 只有当有未完成步骤且没有活跃步骤时才认为是死锁
                    if proj.check_deadlock():
                        logger.error(f"[Scheduler] Deadlock detected for {event.task_id[:8]}")
                        deadlock_event = Event(
                            task_id=event.task_id,
                            event_type=EventType.TASK_FAILED,
                            payload={"reason": "deadlock"}
                        )
                        events_to_publish.append(deadlock_event)

        for evt in events_to_publish:
            try:
                await self.store.append_and_publish(evt)
            except Exception as e:
                logger.error(f"[Scheduler] Failed to publish event: {e}")
                if evt.step_id:
                    async with self._state_lock:
                        self._pending_steps.discard(evt.step_id)

        for item in steps_to_queue:
            await self.queue.put(item)
            logger.debug(f"[Scheduler] Queued step {item[1][:8]}")

    def register_completion(self, task_id: str, future: asyncio.Future):
        self._completion_futures[task_id] = future

    async def shutdown(self):
        self._stop_event.set()
        if self._scan_task:
            self._scan_task.cancel()
            try:
                await self._scan_task
            except asyncio.CancelledError:
                pass


# =========================
# DAG 扩展器（职责分离）
# =========================
class TaskDAGExtender:
    """
    DAG 扩展器 - 负责处理步骤执行结果并扩展任务 DAG
    职责：
    1. 解析步骤执行结果
    2. 确定是否需要创建新步骤
    3. 生成 DAG 更新事件
    """

    def __init__(self, store: EventStore, scheduler: Scheduler, wid: str):
        self.store = store
        self.scheduler = scheduler
        self.wid = wid
        self.tool_registry = ToolRegistry()
        self.skill_registry = SkillRegistry()

    async def register_tool(self, name: str, func: Callable, description: str, params_schema: Optional[Dict] = None):
        """注册工具"""
        self.tool_registry.register(name, func, description, params_schema)

    async def register_skill(self, name: str, skill: Any, description: str = "", params_schema: Optional[Dict] = None):
        """注册 Skill"""
        self.skill_registry.register(name, skill, description, params_schema)

    async def handle_step_result(self, task_id: str, step_id: str, result: Dict, proj: TaskProjection) -> bool:
        """
        处理步骤执行结果并决定是否扩展 DAG

        Args:
            task_id: 任务ID
            step_id: 步骤ID
            result: 步骤执行结果
            proj: 任务投影

        Returns:
            True 如果任务已完成，False 如果还有后续步骤
        """
        next_steps = result.get("next_steps", [])
        single_next = result.get("next_step", "done")
        if single_next != "done" and single_next not in next_steps:
            next_steps.append(single_next)

        is_terminal = result.get("is_terminal", False)

        if not next_steps or next_steps == ["done"] or is_terminal:
            # 🔧 使用新方法检查是否有未完成的步骤（排除当前步骤）
            has_more_steps = proj.has_uncompleted_steps(exclude_step_id=step_id)

            # 🔧 真正完成的条件：没有后续步骤 且 LLM 标记为终端
            only_complete = (not has_more_steps) and is_terminal

            # 🔧 修复：发布 STEP_COMPLETED 事件
            await self.store.append_and_publish(Event(
                task_id=task_id,
                step_id=step_id,
                event_type=EventType.STEP_COMPLETED,
                payload={
                    "output": result.get("output", ""),
                    "next_step": "done",
                    "is_terminal": only_complete,
                    "delta": result.get("delta", {})
                }
            ))
            if only_complete:
                logger.info(f"[{self.wid}] 🏁 Last step completed, waiting for Scheduler to complete task")
            else:
                logger.info(f"[{self.wid}] Step completed, more steps may follow")
            return only_complete

        # 🔧 检查是否已有未完成的后续步骤
        new_steps = []
        created_step_types = set()
        for i, next_step_type in enumerate(next_steps):
            if next_step_type == "done":
                continue
            if next_step_type in created_step_types:
                continue
            existing_incomplete = [
                s.step_id for s in proj.steps.values()
                if s.step_type == next_step_type and s.step_id not in proj.completed and s.step_id not in proj.running
            ]
            if existing_incomplete:
                continue
            created_step_types.add(next_step_type)
            new_step_id = f"step-{uuid.uuid4().hex[:8]}"
            dependencies = result.get("dependencies", [step_id])
            if not dependencies:
                dependencies = [step_id]
            input_data = {"previous": result.get("output", "")[:AgentOSDefaults.STEP_OUTPUT_SUMMARY_LEN]}
            if i > 0:
                input_data["branch"] = i
            new_step = StepDefine(
                step_id=new_step_id,
                step_type=next_step_type,
                input_data=input_data,
                dependencies=dependencies
            )
            new_steps.append(new_step.__dict__)

        if new_steps:
            logger.info(f"[{self.wid}] Creating {len(new_steps)} new steps: {[s['step_type'] for s in new_steps]}")
            step_details = [f"{s['step_id'][:8]}({s['step_type']})" for s in new_steps]
            logger.info(f"[{self.wid}] New steps details: {step_details}")
            await self.store.append_and_publish(Event(
                task_id=task_id,
                event_type=EventType.DAG_UPDATED,
                payload={"steps": new_steps}
            ))

        await self.store.append_and_publish(Event(
            task_id=task_id,
            step_id=step_id,
            event_type=EventType.STEP_COMPLETED,
            payload={
                "output": result.get("output", ""),
                "next_step": next_steps[0] if next_steps else "done",
                "is_terminal": False,
                "delta": result.get("delta", {}),
                "created_steps": [s["step_id"] for s in new_steps]
            }
        ))
        return False


# =========================
# Worker
# =========================
class Worker:
    # 🔧 类级别共享资源：避免每个 Worker 创建独立的客户端
    _llm_client: Optional[AsyncOpenAI] = None
    _search_tool: Optional[TavilySearchTool] = None
    _shared_lock = asyncio.Lock()

    def __init__(
        self,
        wid: str,
        queue: asyncio.Queue,
        store: EventStore,
        scheduler: Scheduler,
        tool_registry: Optional[ToolRegistry] = None,
        skill_registry: Optional[SkillRegistry] = None
    ):
        self.wid = wid
        self.queue = queue
        self.store = store
        self.scheduler = scheduler
        self.tool_registry = tool_registry or ToolRegistry()
        self.skill_registry = skill_registry or SkillRegistry()
        # 🔧 使用独立的 DAG 扩展器
        self.dag_extender = TaskDAGExtender(store, scheduler, wid)
        # 注册默认工具
        self._register_default_tools()
        self._running = True
        self._stop_event = asyncio.Event()
        # 🔧 LLM 客户端和搜索工具将在 run() 中异步初始化
        self.llm: Optional[AsyncOpenAI] = None
        self.search_tool: Optional[TavilySearchTool] = None

    @classmethod
    async def _get_shared_llm(cls) -> AsyncOpenAI:
        """获取共享的 LLM 客户端"""
        if cls._llm_client is None:
            async with cls._shared_lock:
                if cls._llm_client is None:
                    cls._llm_client = AsyncOpenAI(
                        base_url=f"{VLLM_URL}/v1",
                        api_key="sk-ignore",
                        timeout=60.0  # 🔧 LLM 调用超时保持不变
                    )
        return cls._llm_client

    @classmethod
    async def _get_shared_search_tool(cls) -> TavilySearchTool:
        """获取共享的搜索工具"""
        if cls._search_tool is None:
            async with cls._shared_lock:
                if cls._search_tool is None:
                    cls._search_tool = TavilySearchTool()
        return cls._search_tool

    @classmethod
    async def shutdown_shared_resources(cls):
        """关闭共享资源（在所有 Worker 结束后调用）"""
        # 🔧 修复：确保在异步上下文中调用
        if not asyncio.iscoroutinefunction(cls._search_tool.close) if cls._search_tool else True:
            pass  # TavilySearchTool.close 是异步的，需要在异步上下文中调用
        if cls._search_tool:
            try:
                await cls._search_tool.close()
            except RuntimeError:
                # 🔧 在没有运行的 event loop 时跳过
                logger.warning("[Worker] Cannot close search tool: no event loop")
            cls._search_tool = None
        if cls._llm_client:
            try:
                await cls._llm_client.close()
            except RuntimeError:
                # 🔧 在没有运行的 event loop 时跳过
                logger.warning("[Worker] Cannot close LLM client: no event loop")
            cls._llm_client = None

    def _register_default_tools(self):
        """注册默认工具"""
        # 注册 Tavily 搜索
        self.tool_registry.register(
            name="tavily_search",
            func=self._default_search_tool,
            description="使用 Tavily 进行网络搜索，获取最新信息",
            params_schema={
                "type": "object",
                "properties": {
                    "query": {"type": "string", "description": "搜索查询"},
                    "max_results": {"type": "integer", "default": 5, "description": "最大结果数"}
                },
                "required": ["query"]
            }
        )

    async def _default_search_tool(self, query: str, max_results: int = 5) -> Dict:
        """默认 Tavily 搜索工具包装器"""
        # 只使用支持的参数
        return await self.search_tool.search(query=query, max_results=max_results)

    def stop(self):
        self._running = False
        self._stop_event.set()

    async def run(self):
        logger.info(f"[{self.wid}] Worker started")
        # 🔧 异步初始化共享资源
        self.llm = await self._get_shared_llm()
        self.search_tool = await self._get_shared_search_tool()
        try:
            while self._running:
                try:
                    task_id, step_id = await asyncio.wait_for(self.queue.get(), timeout=1.0)
                    logger.info(f"[{self.wid}] Got task from queue: {step_id[:8]}")
                except asyncio.TimeoutError:
                    continue
                except Exception as e:
                    logger.error(f"[{self.wid}] Error getting from queue: {e}")
                    continue
                try:
                    # 🔧 使用新的统一异常处理方法
                    success = await self._process_task_with_retry(task_id, step_id)
                finally:
                    # 🔧 修复：确保 task_done() 只在有效获取时调用
                    try:
                        self.queue.task_done()
                    except ValueError:
                        pass  # 队列已空，忽略
                if not success:
                    logger.warning(f"[{self.wid}] Task processing failed for {step_id[:8]}")
        finally:
            # 🔧 不再关闭共享资源，由 shutdown_shared_resources 统一处理
            logger.info(f"[{self.wid}] Worker shut down")

    async def _process_task(self, task_id: str, step_id: str) -> bool:
        """
        处理任务步骤
        🔧 修复：统一异常处理机制
        """
        proj = None
        step = None

        try:
            proj = self.store.get_projection(task_id)
            if not proj:
                raise TaskNotFoundException(f"Task {task_id[:8]} projection not found")
            if proj.is_terminal:
                logger.debug(f"[{self.wid}] Task {task_id[:8]} is terminal, skipping step {step_id[:8]}")
                return False

            step = proj.steps.get(step_id)
            if not step:
                raise StepNotFoundException(f"Step {step_id[:8]} not found in steps")

            claimed = False
            for attempt in range(3):
                if await self.store.try_claim_step(task_id, step_id, self.wid):
                    claimed = True
                    break
                await asyncio.sleep(0.1 * (attempt + 1))

            if not claimed:
                if proj and step_id in proj.ready_pool:
                    logger.warning(f"[{self.wid}] Failed to claim step {step_id[:8]}, step may be claimed by another worker")
                else:
                    logger.warning(f"[{self.wid}] Failed to claim step {step_id[:8]}, step already claimed or not in ready_pool")
                raise StepClaimFailedException(f"Failed to claim step {step_id[:8]}")

            logger.info(f"[{self.wid}] 🚀 Executing step {step_id[:8]}")
            start_time = time.time()

            try:
                result = await asyncio.wait_for(
                    self._execute_llm(task_id, step_id, step, proj),
                    timeout=AgentOSDefaults.STEP_EXECUTION_TIMEOUT
                )
            except asyncio.TimeoutError:
                raise ExecutionTimeoutException(f"Step {step_id[:8]} LLM timeout")
            except Exception as e:
                raise Exception(f"LLM execution failed: {e}")

            # 🔧 使用独立的 DAG 扩展器处理结果
            await self.dag_extender.handle_step_result(task_id, step_id, result, proj)

            total_time = time.time() - start_time
            logger.info(f"[{self.wid}] ✅ Step {step_id[:8]} total time: {total_time:.1f}s")
            return True

        except AgentOSException:
            # 业务异常，记录日志但继续处理重试逻辑
            raise
        except Exception as e:
            logger.error(f"[{self.wid}] 💥 Exception processing step {step_id[:8]}: {e}", exc_info=True)
            raise

    async def _process_task_with_retry(self, task_id: str, step_id: str) -> bool:
        """
        处理任务步骤（带重试逻辑）
        🔧 修复：分离业务逻辑和重试处理
        """
        try:
            return await self._process_task(task_id, step_id)
        except AgentOSException as e:
            proj = self.store.get_projection(task_id)
            retries = proj.retry_counts.get(step_id, 0) if proj else 0
            step = proj.steps.get(step_id) if proj else None
            max_retries = step.max_retries if step else 3

            if proj is not None and retries < max_retries:
                await self.store.append_and_publish(Event(
                    task_id=task_id,
                    step_id=step_id,
                    event_type=EventType.STEP_RETRY
                ))
                await self.scheduler.on_event(Event(
                    task_id=task_id,
                    step_id=step_id,
                    event_type=EventType.STEP_RETRY
                ))
            else:
                await self.store.append_and_publish(Event(
                    task_id=task_id,
                    step_id=step_id,
                    event_type=EventType.STEP_DEAD,
                    payload={"error": str(e)}
                ))
            return False

    async def _execute_llm(self, task_id: str, step_id: str, step: StepDefine, proj: TaskProjection) -> Dict:
        """统一执行接口：使用 _execute_with_tools"""
        step_type = step.step_type

        # 🔧 如果是 search 步骤，直接调用 Tavily 搜索工具（向后兼容）
        if step_type == "search":
            return await self._execute_search(step, proj)

        # 🔧 使用 _execute_with_tools 方法
        available_tools = self.tool_registry.get_available_tools()
        available_skills = self.skill_registry.get_available_skills()
        return await self._execute_with_tools(task_id, step_id, step, proj, available_tools, available_skills)

    async def _build_context(self, step: StepDefine, proj: TaskProjection) -> str:
        """
        构建 LLM 上下文信息（提取公共逻辑）

        Args:
            step: 当前步骤
            proj: 任务投影

        Returns:
            格式化后的上下文字符串
        """
        dep_results = {}
        for dep_id in step.dependencies:
            record = proj.get_step_record(dep_id)
            if record and record.get("status") == "completed":
                dep_results[dep_id] = record.get("output", "")[:800]

        all_completed = []
        for record in proj.step_records:
            if record.get("status") == "completed" and record["step_id"] not in dep_results:
                all_completed.append({
                    "step_id": record["step_id"],
                    "step_type": record["step_type"],
                    "output": record.get("output", "")[:400],
                    "completed_at": record.get("completed_at", 0)
                })
        all_completed.sort(key=lambda x: x["completed_at"], reverse=True)
        recent_context = all_completed[:3]

        context_parts = []
        if dep_results:
            context_parts.append("=== Direct Dependencies ===")
            for dep_id, output in dep_results.items():
                short_id = dep_id[:8]
                context_parts.append(f"[{short_id}]: {output[:AgentOSDefaults.STEP_OUTPUT_CONTEXT_LEN]}")
        if recent_context:
            context_parts.append("\n=== Additional Context ===")
            for ctx in recent_context:
                short_id = ctx["step_id"][:8]
                context_parts.append(f"[{short_id} {ctx['step_type']}]: {ctx['output'][:200]}")
        return "\n".join(context_parts) if context_parts else "No previous context available."

    async def _execute_search(self, step: StepDefine, proj: TaskProjection) -> Dict:
        """执行 Tavily 搜索"""
        # 从步骤输入数据中获取搜索查询，而不是使用整个任务文本
        search_query = step.input_data.get("query", step.input_data.get("task", proj.task_text))
        current_date = time.strftime('%Y 年%m 月%d 日', time.localtime())

        logger.info(f"[{self.wid}] 🔍 执行搜索：{search_query[:50]}...")
        start_time = time.time()

        try:
            # 调用 Tavily 搜索
            results = await self.search_tool.search(
                query=search_query,
                max_results=5,
                search_depth="basic",  # 🔧 使用 basic 模式，更快
                include_answer=True
            )

            search_time = time.time() - start_time
            logger.info(f"[{self.wid}] ✅ 搜索完成，耗时{search_time:.1f}s，找到{len(results.get('results', []))}条结果")

            # 格式化搜索结果
            formatted_results = self.search_tool.format_results(results)

            # 🔧 检查是否还有未完成的后续步骤（不包括当前已完成的步骤）
            all_future_steps = [
                s.step_type for s in proj.steps.values()
                if s.step_id not in proj.completed and s.step_id not in proj.running
            ]
            has_next_steps = any(
                s_type in ["research", "think", "analyze", "answer", "summarize"]
                for s_type in all_future_steps
            )

            return {
                "output": f"【搜索时间】{current_date}\n\n{formatted_results}",
                "next_step": "analyze" if has_next_steps else "done",
                "is_terminal": not has_next_steps,
                "next_steps": ["analyze"] if has_next_steps else []
            }
        except Exception as e:
            logger.error(f"[{self.wid}] ❌ 搜索失败：{e}")
            return {
                "output": f"搜索失败：{str(e)}",
                "next_step": "analyze",
                "is_terminal": False,
                "next_steps": ["analyze"]
            }

    async def _execute_llm_think(self, step: StepDefine, proj: TaskProjection) -> Dict:
        """使用 LLM 处理非搜索步骤 - 模型自主决策"""
        # 🔧 使用提取的公共方法构建上下文
        full_context = await self._build_context(step, proj)

        # 🔧 新增：获取步骤信息
        input_data = step.input_data
        step_type = step.step_type  # 🔧 修复：添加 step_type 定义
        step_index = input_data.get("step_index", 0)
        total_steps = input_data.get("total_steps", 1)
        is_last_step = input_data.get("is_last_step", False)

        # 🔧 新增：获取当前日期，作为重要信息添加到提示词中
        current_date = time.strftime('%Y年%m月%d日', time.localtime())

        # 🔧 智能判断任务复杂度，动态设置指令
        # task_text 保留供未来使用
        _ = proj.task_text.strip()

        # 🔧 根据任务类型动态设置指令
        if step_type == "search":
            stage_instruction = f"执行网络搜索，收集与任务相关的最新信息。【重要】当前日期是{current_date}，请结合此日期进行搜索，确保获取最新的市场数据和信息。输出搜索结果摘要，至少 150 字。"
        elif step_type == "research":
            stage_instruction = f"深入研究分析，结合已有信息提出见解。【重要】当前日期是{current_date}，请确保分析基于最新信息。输出不少于 200 字。"
        elif step_type == "think":
            # 🔧 关键：让模型自主判断任务复杂度
            stage_instruction = f"""智能分析当前任务：
1. 如果是简单问候或常识问题（如'你好'、'1+1=?'），直接给出简洁回答，设置 is_terminal=true
2. 如果需要实时信息（如新闻、股价、天气），设置 action='tool'，调用 tavily_search 工具
3. 如果需要深度分析，输出详细分析内容（至少 200 字），设置 is_terminal=true

【重要】当前日期是{current_date}，请结合此日期进行判断。"""
        elif step_type == "analyze":
            stage_instruction = f"详细分析，提供专业见解。【重要】当前日期是{current_date}。输出不少于 200 字。"
        elif step_type == "answer":
            stage_instruction = f"直接给出最终答案，清晰明了。【重要】当前日期是{current_date}。"
        elif step_type == "summarize":
            stage_instruction = f"总结关键信息，形成简洁结论。【重要】当前日期是{current_date}。"
        else:
            stage_instruction = f"根据阶段类型 {step_type} 提供详细分析或计划，至少 150 字。【重要】当前日期是{current_date}。"

        # 🔧 关键：如果是最后一步，直接设置为终端步骤
        if is_last_step:
            stage_instruction += "\n\n【重要】这是最后一步，请给出最终结论，设置 is_terminal 为 true。"

        # 🔧 构建统一 Prompt，让模型自主决策
        prompt = f"""你是一个智能助手。当前日期：{current_date}

【任务】
{proj.task_text}

【当前步骤】
{step.step_type}（第{step_index + 1}/{total_steps}步）

【上下文信息】
{full_context}

【执行指令】
{stage_instruction}

【可用工具】
- tavily_search: 网络搜索，获取最新信息

【响应格式】
必须返回如下 JSON 格式，不要包含任何开场白：
{{
    "action": "direct" 或 "tool",
    "tool_name": "tavily_search" 或 null,
    "tool_args": {{"query": "搜索内容"}} 或 null,
    "output": "输出内容",
    "is_terminal": true/false
}}"""
        try:
            resp = await self.llm.chat.completions.create(
                model=MODEL_NAME,
                messages=[{"role": "user", "content": prompt}],
                temperature=0.3,
                max_tokens=6000
            )
            content = resp.choices[0].message.content
            logger.debug(f"[{self.wid}] Raw LLM response: {content[:500]}")

            data = {}
            json_match = re.search(r'(\{.*\})', content, re.DOTALL)
            if json_match:
                try:
                    data = json.loads(json_match.group(1))
                except json.JSONDecodeError:
                    try:
                        fixed = json_match.group(1).replace("'", '"')
                        data = json.loads(fixed)
                    except:
                        data = {"output": content}
            else:
                data = {"output": content}

            if isinstance(data, list):
                data = {"output": json.dumps(data), "is_terminal": True}
            elif not isinstance(data, dict):
                data = {"output": str(data), "is_terminal": True}

            if not data.get("output") or str(data["output"]).strip() == "":
                data["output"] = content if content.strip() else "模型未生成有效内容"

            # 确保返回值包含必需字段
            data.setdefault("is_terminal", False)
            data.setdefault("next_step", "done")
            data.setdefault("next_steps", [])
            data.setdefault("action", "direct")

            # 🔧 确保最后一步是终端步骤
            if is_last_step:
                data["is_terminal"] = True

            # 🔧 检查是否需要调用工具
            if data.get("action") == "tool" and data.get("tool_name") == "tavily_search":
                tool_args = data.get("tool_args", {})
                query = tool_args.get("query", proj.task_text)
                logger.info(f"[{self.wid}] 🔍 调用工具：tavily_search(query={query})")

                # 调用搜索工具
                search_result = await self.search_tool.search(query=query, max_results=5)
                formatted_result = self.search_tool.format_results(search_result)

                return {
                    "output": f"【搜索结果】\n{formatted_result}",
                    "is_terminal": True,
                    "next_step": "done"
                }

            return data
        except Exception as e:
            return {
                "delta": {"error": str(e)},
                "next_step": "done",
                "next_steps": [],
                "dependencies": [],
                "output": f"Error: {str(e)}",
                "is_terminal": True
            }

    async def _execute_with_tools(
        self,
        task_id: str,
        step_id: str,
        step: StepDefine,
        proj: TaskProjection,
        available_tools: List[Dict],
        available_skills: List[Dict]
    ) -> Dict:
        """使用工具的 LLM 调用（Modern Agent 模式）"""
        step_type = step.step_type
        step_index = step.input_data.get("step_index", 0)
        total_steps = step.input_data.get("total_steps", 1)

        # 🔧 使用提取的公共方法构建上下文
        full_context = await self._build_context(step, proj)

        # 获取当前日期
        current_date = time.strftime('%Y年%m月%d日', time.localtime())

        # 构建可用工具描述
        tools_desc = []
        for tool in available_tools:
            func_info = tool.get("function", {})
            tools_desc.append(f"- {func_info.get('name')}: {func_info.get('description')}")

        skills_desc = []
        for skill in available_skills:
            skills_desc.append(f"- {skill.get('name')}: {skill.get('description', '')}")

        # 🔧 Modern Agent Prompt：优先使用工具
        stage_instruction = f"""当前日期：{current_date}
任务：{proj.task_text}
步骤：{step_type}（第{step_index + 1}/{total_steps}步）

【可用工具】
{chr(10).join(tools_desc) if tools_desc else "无可用工具"}

【可用 Skills】
{chr(10).join(skills_desc) if skills_desc else "无可用 Skills"}

【决策规则】
1. 如果有合适的工具，请使用工具并返回结果
2. 如果需要分析/思考，直接输出内容
3. 完成任务时设置 is_terminal=true

【执行指令】
根据任务类型选择合适的工具或直接输出分析结果。

上下文信息：
{full_context}

【响应格式】
必须返回如下 JSON 格式，不要包含任何开场白：
{{
    "action": "tool/skill/analyze/direct",
    "tool_name": "工具名或null",
    "skill_name": "skill名或null",
    "tool_args": {{}},
    "output": "输出内容",
    "is_terminal": true/false,
    "reasoning": "决策理由"
}}"""

        prompt = stage_instruction

        try:
            resp = await self.llm.chat.completions.create(
                model=MODEL_NAME,
                messages=[
                    {"role": "system", "content": "你是一个智能助手。请根据任务选择合适的工具或直接输出答案。"},
                    {"role": "user", "content": prompt}
                ],
                temperature=0.3,
                max_tokens=6000,
                response_format={"type": "json_object"}
            )
            content = resp.choices[0].message.content
            logger.debug(f"[{self.wid}] Raw LLM response: {content[:500]}")

            data = {}
            json_match = re.search(r'(\{.*\})', content, re.DOTALL)
            if json_match:
                try:
                    data = json.loads(json_match.group(1))
                except json.JSONDecodeError:
                    try:
                        fixed = json_match.group(1).replace("'", '"')
                        data = json.loads(fixed)
                    except:
                        data = {"output": content}

            if not isinstance(data, dict):
                data = {"output": str(data), "is_terminal": True}

            # 处理工具调用结果
            action = data.get("action", "direct")
            tool_name = data.get("tool_name")
            skill_name = data.get("skill_name")
            output = data.get("output", "")

            # 🔧 如果 LLM 决定调用工具
            if action == "tool" and tool_name:
                tool_args = data.get("tool_args", {})
                logger.info(f"[{self.wid}] 🔧 调用工具: {tool_name}")
                # 发布工具调用开始事件（可选，依赖 agent_monitor_server）
                monitor_bus = None
                try:
                    from agent_monitor_server import event_bus as monitor_bus
                except ImportError:
                    monitor_bus = None
                if monitor_bus is not None:
                    await monitor_bus.publish(Event(
                        task_id=task_id,
                        step_id=step_id,
                        event_type=EventType.TOOL_CALL_STARTED,
                        payload={"tool_name": tool_name, "args": tool_args}
                    ))
                try:
                    tool_result = await self.tool_registry.execute(tool_name, tool_args)
                except Exception as e:
                    logger.error(f"[{self.wid}] Tool '{tool_name}' execution failed: {e}", exc_info=True)
                    return {
                        "output": f"工具调用失败: {tool_name} - {str(e)}",
                        "next_step": "analyze",
                        "next_steps": ["analyze"],
                        "is_terminal": False,
                        "reasoning": f"工具 {tool_name} 执行失败: {str(e)}"
                    }
                # 发布工具调用完成事件
                if monitor_bus is not None:
                    await monitor_bus.publish(Event(
                        task_id=task_id,
                        step_id=step_id,
                        event_type=EventType.TOOL_CALL_COMPLETED,
                        payload={"tool_name": tool_name, "result": str(tool_result), "args": tool_args}
                    ))
                return {
                    "output": f"【工具结果】\n{tool_result}",
                    "next_step": "analyze",  # 🔧 工具结果通常需要分析
                    "next_steps": ["analyze"],  # 🔧 新增：添加 next_steps
                    "is_terminal": False,
                    "reasoning": data.get("reasoning", "")
                }

            # 🔧 如果 LLM 决定调用 Skill
            elif action == "skill" and skill_name:
                skill_args = data.get("tool_args", {})
                logger.info(f"[{self.wid}] 🛠️  调用 Skill: {skill_name}")
                try:
                    skill_result = await self.skill_registry.execute(skill_name, skill_args)
                except Exception as e:
                    logger.error(f"[{self.wid}] Skill '{skill_name}' execution failed: {e}", exc_info=True)
                    return {
                        "output": f"Skill 调用失败: {skill_name} - {str(e)}",
                        "next_step": "analyze",
                        "is_terminal": False,
                        "reasoning": f"Skill {skill_name} 执行失败: {str(e)}"
                    }
                return {
                    "output": f"【Skill 结果】\n{skill_result}",
                    "next_step": "analyze",
                    "is_terminal": False,
                    "reasoning": data.get("reasoning", "")
                }

            # 🔧 直接输出或分析
            else:
                # 如果 output 为空，使用 content
                if not output or str(output).strip() == "":
                    output = content if content.strip() else "模型未生成有效内容"

                is_terminal = data.get("is_terminal", True)  # 🔧 修复：默认设为 True，让任务可以完成
                reasoning = data.get("reasoning", "")

                return {
                    "output": output,
                    "is_terminal": is_terminal,
                    "reasoning": reasoning,
                    "next_step": "done" if is_terminal else "analyze"
                }

        except asyncio.CancelledError:
            # 取消错误，直接传播
            raise
        except Exception as e:
            logger.error(f"[{self.wid}] Tool execution failed: {e}", exc_info=True)
            # 返回错误结果，不降级到 LLM 处理
            return {
                "output": f"执行失败: {str(e)}",
                "is_terminal": False,
                "reasoning": f"工具执行失败: {str(e)}",
                "next_step": "done"
            }

