class AgentOSException(Exception):
    """ProductionAgentOS 基础异常"""
    pass


class TaskNotFoundException(AgentOSException):
    """任务未找到异常"""
    pass


class StepNotFoundException(AgentOSException):
    """步骤未找到异常"""
    pass


class StepClaimFailedException(AgentOSException):
    """步骤_claim 失败异常"""
    pass


class ExecutionTimeoutException(AgentOSException):
    """执行超时异常"""
    pass


def exception_handler(default_return=None, log_error=True):
    """
    异常处理装饰器
    统一处理异常并返回默认值或重新抛出
    """
    def decorator(func):
        async def wrapper(*args, **kwargs):
            try:
                return await func(*args, **kwargs)
            except AgentOSException:
                raise
            except asyncio.TimeoutError as e:
                if log_error:
                    logger.error(f"[Exception] Timeout in {func.__name__}: {e}")
                raise ExecutionTimeoutException(f"Timeout in {func.__name__}") from e
            except Exception as e:
                if log_error:
                    logger.error(f"[Exception] Error in {func.__name__}: {e}", exc_info=True)
                return default_return
        return wrapper
    return decorator


