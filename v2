def load_skills_from_directory(skills_dir: str = "skills") -> Dict[str, Any]:
    """
    从指定目录加载所有 skills。

    Args:
        skills_dir: skills 目录路径

    Returns:
        dict: {skill_name: skill_object}
    """
    loaded_skills = {}

    if not os.path.exists(skills_dir):
        logger.warning(f"[Skills] Directory '{skills_dir}' does not exist")
        return loaded_skills

    # 获取当前脚本所在目录
    script_dir = os.path.dirname(os.path.abspath(__file__))
    skills_path = os.path.join(script_dir, skills_dir)

    if not os.path.exists(skills_path):
        logger.warning(f"[Skills] Skills directory not found at '{skills_path}'")
        return loaded_skills

    logger.info(f"[Skills] Loading skills from '{skills_path}'")

    for filename in os.listdir(skills_path):
        if filename.endswith('.md') and filename != 'README.md' and filename != 'config.yaml':
            skill_name = filename[:-3]  # 移除 .md 后缀
            file_path = os.path.join(skills_path, filename)

            # 读取 skill 文件内容（用于后续扩展）
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read()

            # 解析 YAML front matter
            skill_meta = _parse_skill_frontmatter(content)

            # 创建动态 skill 对象
            skill_obj = DynamicSkill(
                name=skill_name,
                file_path=file_path,
                content=content,
                meta=skill_meta
            )

            loaded_skills[skill_name] = skill_obj
            logger.info(f"[Skills] Loaded skill: {skill_name}")

    return loaded_skills


def _parse_skill_frontmatter(content: str) -> Dict[str, Any]:
    """
    解析 Markdown 文件的 YAML front matter。

    Args:
        content: 文件内容

    Returns:
        dict: front matter 元数据
    """
    meta = {}

    # 检查是否有 front matter
    if not content.startswith('---'):
        return meta

    try:
        # 找到 front matter 结束位置
        parts = content.split('---', 2)
        if len(parts) >= 3:
            yaml_content = parts[1].strip()
            # 简单解析 YAML（支持基本的 key: value）
            for line in yaml_content.split('\n'):
                if ':' in line:
                    key, value = line.split(':', 1)
                    meta[key.strip()] = value.strip().strip('"').strip("'")
    except Exception as e:
        logger.warning(f"[Skills] Failed to parse frontmatter: {e}")

    return meta


class DynamicSkill:
    """
    动态加载的 Skill 对象。
    提供 run 方法供 SkillRegistry 调用。
    """

    def __init__(self, name: str, file_path: str, content: str, meta: Dict[str, Any]):
        self.name = name
        self.file_path = file_path
        self.content = content
        self.meta = meta
        self.description = meta.get('description', '')

    async def run(self, **kwargs) -> Dict[str, Any]:
        """
        执行 skill。
        目前返回 skill 元数据和内容摘要。

        Args:
            **kwargs: skill 参数

        Returns:
            dict: skill 执行结果
        """
        logger.info(f"[DynamicSkill] Running '{self.name}' with args: {list(kwargs.keys())}")

        return {
            "skill_name": self.name,
            "description": self.description,
            "meta": self.meta,
            "content_length": len(self.content),
            "success": True
        }

